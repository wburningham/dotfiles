# Initialize the completion system
autoload -Uz compinit && compinit

# Trying out this alias
alias c='chezmoi'

# aliases
alias ls='lsd'
alias la='lsd -A'
alias ll='lsd -l'
alias lla='lsd -lA'
alias llt='lsd -l --tree'
alias lt='lsd --tree'

# Source ENV variables
[ -f "$HOME/.env" ] && . "$HOME/.env"


# use mcfly for ctrl+r
eval "$(mcfly init zsh)"
