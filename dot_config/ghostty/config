#
# https://ghostty.org/docs/config/reference
#

auto-update-channel = tip
working-directory = "/Users/wesb/code/go/src/gitlab-app.eng.qops.net"

# makes it darker like it was before https://github.com/mbadolato/iTerm2-Color-Schemes/commit/506ab2b98b6546d1dc46327dfa1e1e3f8363fbc0
palette = "0=#1b1b1b"
background = "#1b1b1b"

# Fonts
# font-family = "Symbols Nerd Font Mono"
font-family = "Maple Mono"
font-family-bold = "Maple Mono"
font-family-italic = "Maple Mono"
font-family-bold-italic = "Maple Mono"
font-size = 17
adjust-underline-position = 4

# Mouse
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

# Theme
# theme = CutiePro
# theme = Firewatch
# theme = NightLion v2
theme = "Pencil Dark"
cursor-invert-fg-bg = true
background-opacity = 1
window-theme = ghostty
cursor-style = block


# keybindings
# Cmd+arrows → same bytes as Zed terminal (C-a / C-e); Neovim maps these in insert mode (see dot_config/nvim/init.lua)
keybind = super+left=text:\x01
keybind = super+right=text:\x05
# Cmd+up/down → Esc + gg / G (top / bottom of buffer in Vim); matches Zed Terminal keymap
keybind = super+up=text:\x1bgg
keybind = super+down=text:\x1bG
