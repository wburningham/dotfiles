# BEGIN better git config https://blog.gitbutler.com/how-git-core-devs-configure-git/#listing-branches

# branches
[column]
    ui = auto
[branch]
    sort = -committerdate
[init]
	defaultBranch = master

# tags
[tag]
    sort = version:refname
# diffs
[diff]
    algorithm = histogram
    colorMoved = plain
    mnemonicPrefix = true
    renames = true

# pushing
[push]
	default = simple # default since 2.0
	autoSetupRemote = true # all first-time push on new branches will automatically set the default upstream https://git-scm.com/docs/git-config#Documentation/git-config.txt-pushautoSetupRemote
	followTags = true # push all tags that you have locally that aren’t on the server, every time you push anything.



